# ---------------------------------------------------------------------------
# Campus Connect environment
#
# Leave these BLANK to run in the fully-functional in-browser DEMO mode
# (no backend needed — data persists in localStorage).
#
# Fill them in to switch the whole app to Supabase (production):
#   1. Create a project at https://supabase.com
#   2. Run the SQL in supabase/migrations (see README)
#   3. Copy the Project URL + anon/publishable key below
# ---------------------------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public site URL — used for SEO, sitemap and Open Graph tags.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
